__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Secrets and local-only environment files
.env
.env.*
*.pem
*.key
*.sqlite
*.sqlite3
*.db
*.xlsx
*.xlsm
*.xls
*secret*
*token*
*password*
*credential*

# Runtime configuration and data. Keep only README/.gitkeep placeholders.
config/*
!config/.gitkeep
!config/README.md

data/*
!data/.gitkeep
!data/README.md

archive/*
!archive/.gitkeep
!archive/README.md

backups/*
!backups/.gitkeep
!backups/README.md

logs/*
!logs/.gitkeep
!logs/README.md

attachments/
screenshots/
captures/
exports/

# Local predictive maintenance report exports stay out of Git.
predictive_summary_*.txt
predictive_report_*.txt

# Local media, design notes, and generated exports are NDA-sensitive unless reviewed.
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.bmp
*.tiff
*.pdf
*.log
*.zip
*.bak
~$*

!assets/branding/nolato_logo_placeholder.png
!assets/branding/nolato_logo.png
